};

const SECTION_TITLES = {
  ro: { s: "🔵 Simptome — ce spune pacientul", c: "🟠 Cauze — de ce s-a întâmplat", t: "🟢 Tratament — ce recomandă farmacistul", d: "🟣 Dialog tip pentru acest subiect" },
  fr: { s: "🔵 Symptômes — ce que dit le patient", c: "🟠 Causes — pourquoi c'est arrivé", t: "🟢 Traitement — ce que recommande le pharmacien", d: "🟣 Dialogue type pour ce sujet" }
};

function setLang(lang) {
  currentLang = lang;
  document.getElementById("btn-ro").classList.toggle("active", lang === "ro");
  document.getElementById("btn-fr").classList.toggle("active", lang === "fr");
  renderAll();
}

function showCard(index) {
  currentCard = index;
  renderAll();
}

function renderAll() {
  renderTabs();
  renderCards();
}

function renderTabs() {
  const tabs = document.getElementById("tabs");
  tabs.innerHTML = "";
  TAB_LABELS[currentLang].forEach((label, i) => {
    const btn = document.createElement("button");
    btn.className = "tab" + (i === currentCard ? " active" : "");
    btn.textContent = label;
    btn.onclick = () => showCard(i);
    tabs.appendChild(btn);
  });
}

function renderCards() {
  const container = document.getElementById("cards");
  container.innerHTML = "";
  const lang = currentLang;
  const titles = SECTION_TITLES[lang];
  const farmLabel = lang === "ro" ? "👨‍⚕️ Farmacist" : "👨‍⚕️ Pharmacien";
  const patLabel = lang === "ro" ? "🧑 Pacient" : "🧑 Patient";

  SUBJECTS.forEach((s, i) => {
    const card = document.createElement("div");
    card.className = "card" + (i === currentCard ? " active" : "");

    card.innerHTML = `
      <div class="card-emoji">${s.emoji}</div>
      <div class="card-title">${s.title[lang]}</div>

      <div class="section section-symptome">
        <div class="section-title">${titles.s}</div>
        ${s.simptome[lang].map(x => `<div class="item"><div class="item-dot"></div><div>${x}</div></div>`).join("")}
      </div>

      <div class="section section-cause">
        <div class="section-title">${titles.c}</div>
        ${s.cauze[lang].map(x => `<div class="item"><div class="item-dot"></div><div>${x}</div></div>`).join("")}
      </div>

      <div class="section section-traitement">
        <div class="section-title">${titles.t}</div>
        ${s.tratament[lang].map(x => `<div class="item"><div class="item-dot"></div><div>${x}</div></div>`).join("")}
      </div>

      <div class="section section-dialog">
        <div class="section-title">${titles.d}</div>
        ${s.dialog[lang].map(d => `
          <div class="dialog-line dialog-${d.role}">
            <div class="dialog-who">${d.role === "F" ? farmLabel : patLabel}</div>
            ${d.text}
          </div>
        `).join("")}
      </div>

      <div class="tip">${s.tip[lang]}</div>
    `;

    container.appendChild(card);
  });
}

